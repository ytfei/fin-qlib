# API Server Configuration
# Copy this file to .env and update with your values

# API Token for authentication
# Leave empty to disable authentication (not recommended for production)
API_TOKEN=

# API Server Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# Qlib Configuration
# Project directory (all relative paths will be resolved relative to this)
# Leave empty to use current directory
PROJECT_DIR=
CONFIG_PATH=config/online_config.yaml
LOG_DIR=data/logs

# Provider URI for Qlib data
# QLIB_PROVIDER_URI=~/.qlib/tushare_data/cn_data

# Region for Qlib (cn, us, etc.)
# QLIB_REGION=cn
